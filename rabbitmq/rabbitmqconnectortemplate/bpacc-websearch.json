{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "BPACC | Web Information Retrieval",
  "id": "io.bpacc.connectors.WebSearch.v1",
  "description": "Performs a web search to enrich visitor or contextual data.",
  "metadata": {
    "keywords": []
  },
  "version": 1,
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "engines": {
    "camunda": "^8.3"
  },
  "groups": [
    {
      "id": "taskDefinitionType",
      "label": "Task definition type"
    },
    {
      "id": "authentication",
      "label": "Authentication"
    },
    {
      "id": "routing",
      "label": "Routing"
    },
    {
      "id": "message",
      "label": "Capability Parameters"
    },
    {
      "id": "constraints",
      "label": "Constraints"
    },
    {
      "id": "connector",
      "label": "Connector"
    },
    {
      "id": "output",
      "label": "Output mapping"
    },
    {
      "id": "error",
      "label": "Error handling"
    },
    {
      "id": "retries",
      "label": "Retries"
    }
  ],
  "properties": [
    {
      "id": "taskDefinitionType",
      "value": "io.camunda:connector-rabbitmq:1",
      "group": "taskDefinitionType",
      "binding": {
        "property": "type",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "authentication.authType",
      "value": "uri",
      "group": "authentication",
      "binding": {
        "name": "authentication.authType",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "authentication.uri",
      "label": "RabbitMQ URI",
      "description": "Secret reference to RabbitMQ connection URI (e.g. secrets.RABBITMQ_URI)",
      "optional": false,
      "value": "secrets.RABBITMQ_URI",
      "constraints": {
        "notEmpty": true,
        "pattern": {
          "value": "^(=|(amqps?://|secrets|\\{\\{).*$)",
          "message": "Must start with amqp(s):// or contain a secret reference"
        }
      },
      "feel": "optional",
      "group": "authentication",
      "binding": {
        "name": "authentication.uri",
        "type": "zeebe:input"
      },
      "type": "String"
    },
    {
      "id": "routing.exchange",
      "value": "bpacc.intent",
      "group": "routing",
      "binding": {
        "name": "routing.exchange",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "routing.routingKey",
      "value": "queue-cloud",
      "group": "routing",
      "binding": {
        "name": "routing.routingKey",
        "type": "zeebe:input"
      },
      "type": "Hidden"
    },
    {
      "id": "message.properties",
      "label": "AMQP Properties",
      "optional": true,
      "value": "={}",
      "feel": "required",
      "group": "message",
      "binding": {
        "name": "message.properties",
        "type": "zeebe:input"
      },
      "type": "Text"
    },
    {
      "id": "message.body",
      "label": "Capability Parameters",
      "description": "Parameters:\n- Search Query (search_query): xsd:string",
      "optional": false,
      "value": "= {\"cap_id\": \"cap:data.web_search\", \"constraints\": {\"region\": constraints.region, \"latency\": constraints.latency}, \"params\": {\"search_query\": \"\"}}",
      "feel": "required",
      "constraints": {
        "notEmpty": true
      },
      "group": "message",
      "binding": {
        "name": "message.body",
        "type": "zeebe:input"
      },
      "type": "Text"
    },
    {
      "id": "constraints.region",
      "label": "Data Region",
      "description": "Geographic region constraint for data sovereignty",
      "value": "eu",
      "group": "constraints",
      "binding": {
        "name": "constraints.region",
        "type": "zeebe:input"
      },
      "type": "Dropdown",
      "choices": [
        {
          "name": "European Union (GDPR)",
          "value": "eu"
        },
        {
          "name": "United States",
          "value": "us"
        },
        {
          "name": "Asia-Pacific",
          "value": "apac"
        }
      ]
    },
    {
      "id": "constraints.latency",
      "label": "Latency Profile",
      "description": "Required latency tier for this capability",
      "value": "standard",
      "group": "constraints",
      "binding": {
        "name": "constraints.latency",
        "type": "zeebe:input"
      },
      "type": "Dropdown",
      "choices": [
        {
          "name": "Critical (< 20ms)",
          "value": "critical"
        },
        {
          "name": "Standard (< 500ms)",
          "value": "standard"
        },
        {
          "name": "Best-effort (> 500ms)",
          "value": "best-effort"
        }
      ]
    },
    {
      "id": "version",
      "value": "1",
      "group": "connector",
      "binding": {
        "key": "elementTemplateVersion",
        "type": "zeebe:taskHeader"
      },
      "type": "Hidden"
    },
    {
      "id": "id",
      "value": "io.bpacc.connectors.WebSearch.v1",
      "group": "connector",
      "binding": {
        "key": "elementTemplateId",
        "type": "zeebe:taskHeader"
      },
      "type": "Hidden"
    },
    {
      "id": "resultVariable",
      "label": "Result variable",
      "description": "Name of variable to store the response in",
      "group": "output",
      "binding": {
        "key": "resultVariable",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    },
    {
      "id": "resultExpression",
      "label": "Result expression",
      "value": "= {status: response.body.status, result: response.body.result}",
      "feel": "required",
      "group": "output",
      "binding": {
        "key": "resultExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "errorExpression",
      "label": "Error expression",
      "value": "= if error.code = \"RABBITMQ_ERROR\" then bpmnError(\"CAPABILITY_FAILED\", error.message) else null",
      "feel": "required",
      "group": "error",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "retryBackoff",
      "label": "Retry backoff",
      "value": "PT5S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}