            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter25 ;
            owl:onProperty :hasInputParameter ],
        :ActuationService .

:VideoCapture_Service a owl:Class ;
