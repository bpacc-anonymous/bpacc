            owl:onProperty [ owl:inverseOf :hasInputParameter ] ;
            owl:someValuesFrom :OCR_Service ],
        :InputParameter,
        owl:NamedIndividual ;
    :paramName "video_base64"^^xsd:string ;
    :paramType "string"^^xsd:string .

