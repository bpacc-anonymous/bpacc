:DataStructuring_Service a owl:Class ;
    rdfs:comment "implementations: DataStructuring_LLM_Mistral"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "standard"^^xsd:string ;
            owl:onProperty :latencyProfile ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter2 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "none"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter3 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        :ProcessingService .

:InteractionService a owl:Class ;
    rdfs:label "Interaction Service"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :isDeployedOn ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( :EndpointNode :EdgeNode :CloudNode ) ] ],
        :ContinuumService ;
    skos:definition """
        Super-class Si. Services that interface with human users.
        Placement: Endpoint ∪ Edge ∪ Cloud (all three tiers).
        Examples: Streamlit UI, dashboard, consent form, sales handoff interface.
    """@en .

:LLMText_Service a owl:Class ;
    rdfs:comment "implementations: LLMText_Whisper_Mistral"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :inputparameter24 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "edge-preferred"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter23 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "standard"^^xsd:string ;
            owl:onProperty :latencyProfile ],
        :ProcessingService .

:ObjectDetection_Service a owl:Class ;
    rdfs:comment "implementations: ObjectDetection_LLM_Mistral"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter20 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "edge-preferred"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
