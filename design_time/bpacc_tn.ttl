@prefix : <http://bpacc.bpacc.com/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology ;
    dcterms:creator "Anonymous Author"^^xsd:string ;
    dcterms:description """
        Base TBox for the BPACC architecture (Business Process Aware Computing Continuum).
        Extends SOSA/SSN with compute continuum topology, service taxonomy,
        placement axioms, and governance constraints.
        Reference: Al-Dulaimy et al., Internet of Things, vol. 27, 2024.
    """^^xsd:string ;
    dcterms:title "BPACC Base TBox Ontology"^^xsd:string ;
    owl:imports <http://www.w3.org/ns/sosa> ;
    owl:versionInfo "0.2.0"^^xsd:string .

:CapabilityProfile a owl:Class ;
    rdfs:label "Capability Profile"@en ;
    skos:definition """
        A Capability Profile c ∈ K as defined in Section III-A-2:
        c = ⟨ID, Ic, Qc, Pc⟩
        - ID  : semantic identifier (AbstractCapability IRI)
        - Ic  : required functional input parameters (hasInputParameter)
        - Qc  : applicable SLOs (latencyProfile)
        - Pc  : local governance constraints (dataLocality, targetNode, region)
        Serialized as a Capability Contract JSON payload for B1 and B3.
    """@en .

:DataLocalityConstraint a owl:Class ;
    rdfs:label "Data Locality Constraint"@en ;
    rdfs:subClassOf :GovernanceConstraint ;
    skos:definition """
        Constrains where data produced or consumed by a service may reside.
        GDPR use case: biometric data must not leave the Edge.
        Maps to governance.data_locality in the Capability Contract payload.
    """@en .

:RegionConstraint a owl:Class ;
    rdfs:label "Region Constraint"@en ;
    rdfs:subClassOf :GovernanceConstraint ;
    skos:definition """
        Constrains the geographic region of the deployment node.
        GDPR use case: personal data must remain within EU territory.
        B1 contextualises this from business constraints in the BPMN.
        B3 verifies compliance at artifact validation time.
        Maps to governance.region in the Capability Contract payload.
    """@en .

:hasGovernanceConstraint a owl:ObjectProperty ;
    rdfs:label "has governance constraint"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range :GovernanceConstraint ;
    skos:definition "Relates a service to its local governance constraints Pc."@en .

:implementsCapability a owl:ObjectProperty ;
    rdfs:label "implements capability"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range :AbstractCapability ;
    skos:definition """
        Relates a concrete service implementation to its abstract capability
        class in K. Enables abstract/instance separation (Section III-A-2).
    """@en .

:nodeCapacity a owl:DatatypeProperty ;
    rdfs:label "node capacity"@en ;
    rdfs:domain :ContinuumNode ;
    rdfs:range xsd:integer ;
    skos:definition """
        Abstract capacity score of a continuum node.
        Encodes the invariant Cap(x) < Cap(y) < Cap(z)
        for x∈P, y∈E, z∈C from [1].
    """@en .

:paramLabel a owl:DatatypeProperty ;
    rdfs:label "parameter label"@en ;
    rdfs:domain :InputParameter ;
    rdfs:range xsd:string ;
    skos:definition """
        Human-readable label displayed in Camunda Modeler for the Business Analyst.
        Example: 'Image Source (base64 encoded)', 'Recording Duration (seconds)'.
    """@en .

:paramName a owl:DatatypeProperty ;
    rdfs:label "parameter name"@en ;
    rdfs:domain :InputParameter ;
    rdfs:range xsd:string ;
    skos:definition """
        Technical variable name (key) used in the Capability Contract params payload.
        Example: 'video_base64', 'duration_seconds', 'text_to_say'.
    """@en .

:paramType a owl:DatatypeProperty ;
    rdfs:label "parameter type"@en ;
    rdfs:domain :InputParameter ;
    rdfs:range xsd:string ;
    skos:definition """
        Expected XSD data type of the parameter.
        Allowed values: 'string', 'float', 'boolean', 'integer'.
    """@en .

:serviceId a owl:DatatypeProperty ;
    rdfs:label "service ID"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range xsd:string ;
    skos:definition "Unique identifier of the service, corresponds to M(s).id."@en .

:serviceVersion a owl:DatatypeProperty ;
    rdfs:label "service version"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range xsd:string .

:AbstractCapability a owl:Class ;
    rdfs:label "Abstract Capability"@en ;
    skos:definition """
        An abstract service capability in K.
        Identified by a semantic ID in the TBox.
        Implemented by one or more concrete ContinuumService instances.
        The Business Analyst interacts only with AbstractCapability,
        never with concrete implementations.
    """@en .

:AudioRecording_Service a owl:Class ;
    rdfs:comment "implementations: AudioRecording_NAOqi_Pepper"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :inputparameter21 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        [ a owl:Restriction ;
            owl:hasValue "edge-only"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue "standard"^^xsd:string ;
            owl:onProperty :latencyProfile ],
        :SensingService .

:OCR_Service a owl:Class ;
