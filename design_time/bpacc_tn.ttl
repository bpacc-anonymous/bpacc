            owl:onProperty :hasInputParameter ],
        :ProcessingService .

:Robot_Service a owl:Class ;
    rdfs:comment "implementations: Robot_Behavior_Interaction"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EndpointNode ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter35 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "endpoint-only"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue "critical"^^xsd:string ;
            owl:onProperty :latencyProfile ],
