            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        :ActuationService .

:StorageService a owl:Class ;
    rdfs:label "Storage Service"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( :EdgeNode :CloudNode ) ] ;
            owl:onProperty :isDeployedOn ],
        [ a owl:Restriction ;
            owl:onProperty :isDeployedOn ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( :EdgeNode :CloudNode ) ] ],
        :ContinuumService ;
    skos:definition """
        Super-class Sd. Services that persist or retrieve data.
        Placement: Edge ∪ Cloud — persistent storage requires stable infrastructure.
        Examples: CRM, database, file storage.
    """@en .

:VisitorInteraction_Service a owl:Class ;
    rdfs:comment "implementations: VisitorInteraction_Streamlit_UI"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        [ a owl:Restriction ;
            owl:hasValue "standard"^^xsd:string ;
            owl:onProperty :latencyProfile ],
        [ a owl:Restriction ;
            owl:hasValue "none"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter34 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter33 ;
            owl:onProperty :hasInputParameter ],
        :InteractionService .

:ActuationService a owl:Class ;
    rdfs:label "Actuation Service"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :EndpointNode ;
            owl:onProperty :isDeployedOn ],
        :ContinuumService,
        sosa:Actuator ;
    skos:definition """
        Super-class Sa. Services that act on the physical world.
        Placement: Endpoint only — actuation requires physical proximity.
        Examples: text-to-speech on robot, motor control, relay actuation.
    """@en .

:GovernanceConstraint a owl:Class ;
    rdfs:label "Governance Constraint"@en ;
    skos:definition """
        A governance rule r ∈ Rlocal applicable to a service.
        Evaluated by B3 (Business Policy Repository) via fvalidate.
    """@en .

:SensingService a owl:Class ;
    rdfs:label "Sensing Service"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :isDeployedOn ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( :EndpointNode :EdgeNode :CloudNode ) ] ],
        :ContinuumService,
        sosa:Sensor ;
    skos:definition """
        Super-class Ss. Services that capture data from the physical world.
        Placement: Endpoint ∪ Edge ∪ Cloud (all three tiers).
        Examples: audio recording, video capture, environmental sensors.
    """@en .

:canOffloadTo a owl:ObjectProperty ;
    rdfs:label "can offload to"@en ;
    rdfs:domain :ContinuumNode ;
    rdfs:range :ContinuumNode ;
    skos:definition """
        Directed offloading relation between continuum tiers.
        Axioms: P→E, P→C, E→C (from [1]).
    """@en .

:EndpointNode a owl:Class ;
    rdfs:label "Endpoint Node"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :canOffloadTo ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( :EdgeNode :CloudNode ) ] ],
        :ContinuumNode ;
    skos:definition """
        Tier P — IoT endpoints, embedded devices, robots.
        Lowest capacity tier. Cannot offload to other Endpoints.
        In BPACC use case: SoftBank Pepper robot (Intel Atom E3845, 4GB RAM).
    """@en ;
    skos:example "SoftBank Pepper, Raspberry Pi, Arduino"@en .

:CRM_Service a owl:Class ;
    rdfs:comment "implementations: CRM_Storage_Service"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        [ a owl:Restriction ;
            owl:hasValue "strict"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter26 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter30 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter31 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "critical"^^xsd:string ;
            owl:onProperty :latencyProfile ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter28 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter29 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter27 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter32 ;
            owl:onProperty :hasInputParameter ],
        :StorageService .

:SalesNotification_Service a owl:Class ;
    rdfs:comment "implementations: SalesNotification_Filter"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter17 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter16 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "none"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter15 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter13 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter18 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter12 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter14 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "standard"^^xsd:string ;
            owl:onProperty :latencyProfile ],
        :ProcessingService .

:VisitorQualification_Service a owl:Class ;
    rdfs:comment "implementations: VisitorQualification_LLM_Mistral"^^xsd:string ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue :inputparameter6 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter8 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter10 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter4 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter9 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "none"^^xsd:string ;
            owl:onProperty :dataLocality ],
        [ a owl:Restriction ;
            owl:hasValue "standard"^^xsd:string ;
            owl:onProperty :latencyProfile ],
        [ a owl:Restriction ;
            owl:onProperty :targetNode ;
            owl:someValuesFrom :EdgeNode ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter7 ;
            owl:onProperty :hasInputParameter ],
        [ a owl:Restriction ;
            owl:hasValue "eu"^^xsd:string ;
            owl:onProperty :region ],
        [ a owl:Restriction ;
            owl:hasValue :inputparameter5 ;
            owl:onProperty :hasInputParameter ],
        :ProcessingService .

:isDeployedOn a owl:ObjectProperty ;
    rdfs:label "is deployed on"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range :ContinuumNode ;
    skos:definition """
        Relates a ContinuumService instance to the ContinuumNode on which
        it is deployed. Used by HermiT to enforce placement axioms at ABox level.
        The scheduler selects the concrete instance at runtime via Meligible.
    """@en .

:ProcessingService a owl:Class ;
    rdfs:label "Processing Service"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :isDeployedOn ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( :EdgeNode :CloudNode ) ] ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( :EdgeNode :CloudNode ) ] ;
            owl:onProperty :isDeployedOn ],
        :ContinuumService ;
    skos:definition """
        Super-class Sp. Services that transform, analyze, or enrich data.
        Placement: Edge ∪ Cloud — requires compute capacity above Endpoint tier.
        Examples: OCR, LLM inference, web search, lead scoring, object detection.
    """@en .

:CloudNode a owl:Class ;
    rdfs:label "Cloud Node"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onProperty :canOffloadTo ],
        :ContinuumNode ;
    skos:definition """
        Tier C — Cloud data centers, on-premise clusters.
        Highest capacity. Receives offloaded workloads from Endpoints and Edge.
        In BPACC use case: on-premise cluster (~150 vCPU, 2.1TB RAM, Harvester/Rancher).
    """@en ;
    skos:example "AWS EC2, on-premise Kubernetes cluster, HPC node"@en .

:ContinuumNode a owl:Class ;
    rdfs:label "Continuum Node"@en ;
    rdfs:subClassOf sosa:Platform ;
    skos:definition """
        An execution node in the compute continuum.
        Subclasses correspond to the three tiers defined in [1]:
        Endpoint (P), Edge (E), Cloud (C).
    """@en .

:dataLocality a owl:DatatypeProperty ;
    rdfs:label "data locality"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range xsd:string ;
    skos:definition """
        Data placement constraint for GDPR compliance. Encodes Pc.
        Allowed values: 'edge-only', 'endpoint-only', 'edge-preferred',
        'cloud-only', 'none', 'strict'.
        Maps to governance.data_locality in the Capability Contract payload.
    """@en .

:latencyProfile a owl:DatatypeProperty ;
    rdfs:label "latency profile"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range xsd:string ;
    skos:definition """
        QoS latency tier for the service. Encodes Qc in the Capability Profile.
        Allowed values: 'critical', 'standard', 'best-effort'.
        Maps to qos.latency in the Capability Contract payload.
        Used by B1 for contextual matching and by B3 for fvalidate.
    """@en .

:region a owl:DatatypeProperty ;
    rdfs:label "region"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :ContinuumService :ContinuumNode ) ] ;
    rdfs:range xsd:string ;
    skos:definition """
        Geographic region constraint for GDPR compliance. Encodes Pc.
        Allowed values: 'eu', 'fr', 'us', 'ap', etc.
        On ContinuumService : required deployment region for this capability.
        On ContinuumNode    : actual region of the node.
        B1 contextualises this from business constraints expressed in the BPMN.
        B3 verifies that the artifact's node region matches the service constraint.
        Maps to governance.region in the Capability Contract payload.
    """@en .

:targetNode a owl:ObjectProperty ;
    rdfs:label "target node"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range :ContinuumNode ;
    skos:definition """
        Suggested target continuum node tier for this capability.
        Encodes Pc (local governance constraint) in the Capability Profile.
        Used by B1 for contextual matching and by B3 for fvalidate.
        Final placement is resolved by the scheduler at runtime via Meligible.
        Not an OWL restriction — descriptive, queryable via SPARQL.
    """@en .

:ContinuumService a owl:Class ;
    rdfs:label "Continuum Service"@en ;
    skos:definition """
        Top-level class for all invocable services in the BPACC taxonomy.
        Excludes operational infrastructure services (Sop) per the
        Exclusion property of the reference model [1].
    """@en .

:EdgeNode a owl:Class ;
    rdfs:label "Edge Node"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :canOffloadTo ;
            owl:someValuesFrom :CloudNode ],
        :ContinuumNode ;
    skos:definition """
        Tier E — Edge gateways, local compute clusters.
        Medium capacity. Receives offloaded workloads from Endpoints.
        In BPACC use case: Intel Core i7 gateway (16GB RAM, RKE2).
    """@en ;
    skos:example "Edge gateway, local Kubernetes cluster, fog node"@en .

:InputParameter a owl:Class ;
    rdfs:label "Input Parameter"@en ;
    skos:definition """
        Describes a parameter required by a capability at runtime.
        Encodes Ic in the Capability Profile.
        Serialized as the params field of the Capability Contract payload.
        Properties: paramName (key), paramLabel (Camunda label), paramType (XSD type).
    """@en .

:hasInputParameter a owl:ObjectProperty ;
    rdfs:label "has input parameter"@en ;
    rdfs:domain :ContinuumService ;
    rdfs:range :InputParameter ;
    skos:definition """
        Relates a ContinuumService to its required functional input parameters Ic.
        Used by B1 to populate the params field of the Capability Contract.
    """@en .

[] a owl:AllDisjointClasses ;
    owl:members ( :SensingService :ActuationService :ProcessingService :StorageService :InteractionService ) .

[] a owl:AllDisjointClasses ;
    owl:members ( :EndpointNode :EdgeNode :CloudNode ) .

