@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix bpacc:   <http://bpacc.bpacc.com/ontology#> .

# ══════════════════════════════════════════════════════════════════════════════
# Ontologie BPACC — T₀ (Base TBox) v0.2.0
# Étend SOSA pour couvrir le Compute Continuum (Section III-A du papier)
#
# T₀ encode :
#   - Les 5 super-classes de services (Ss, Sa, Sp, Sd, Si)
#   - La topologie continuum 3 tiers (Endpoint, Edge, Cloud)
#   - Les axiomes de placement par super-classe (OWL restrictions)
#     → vérifiés par HermiT au niveau ABox (instances)
#   - Les propriétés structurées du Capability Profile ⟨ID, Ic, Qc, Pc⟩
#     → Ic : hasInputParameter, paramName, paramLabel, paramType
#     → Qc : latencyProfile
#     → Pc : dataLocality, targetNode, region
#   - Les invariants de capacité du continuum [1]
#
# Changements v0.2.0 vs v0.1.0 :
#   + bpacc:targetNode          ObjectProperty descriptive (Pc → B1, B3)
#   + bpacc:hasInputParameter   ObjectProperty vers InputParameter (Ic)
#   + bpacc:InputParameter      Classe pour les paramètres fonctionnels
#   + bpacc:paramName           DatatypeProperty — clé JSON du paramètre
#   + bpacc:paramLabel          DatatypeProperty — label Camunda Modeler
#   + bpacc:paramType           DatatypeProperty — type XSD attendu
#   + bpacc:latencyProfile      DatatypeProperty (Qc — critical/standard/best-effort)
#   + bpacc:region              DatatypeProperty (Pc — contrainte géographique GDPR)
#   + bpacc:RegionConstraint    Sous-classe de GovernanceConstraint
#
# Import : SOSA uniquement (pas d'iot-lite)
# ══════════════════════════════════════════════════════════════════════════════

bpacc:
    a owl:Ontology ;
    owl:imports <http://www.w3.org/ns/sosa/> ;
    dcterms:title "BPACC Base TBox Ontology"^^xsd:string ;
    dcterms:description """
        Base TBox for the BPACC architecture (Business Process Aware Computing Continuum).
        Extends SOSA/SSN with compute continuum topology, service taxonomy,
        placement axioms, and governance constraints.
        Reference: Al-Dulaimy et al., Internet of Things, vol. 27, 2024.
    """^^xsd:string ;
    dcterms:creator "Anonymous Author"^^xsd:string ;
    owl:versionInfo "0.2.0"^^xsd:string .


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 1 — TOPOLOGIE CONTINUUM
# Formalise les 3 tiers P, E, C et leurs invariants de capacité [1]
# Cap(x) < Cap(y) < Cap(z) ∀ x∈P, y∈E, z∈C
# ══════════════════════════════════════════════════════════════════════════════

bpacc:ContinuumNode a owl:Class ;
    rdfs:subClassOf sosa:Platform ;
    rdfs:label "Continuum Node"@en ;
    skos:definition """
        An execution node in the compute continuum.
        Subclasses correspond to the three tiers defined in [1]:
        Endpoint (P), Edge (E), Cloud (C).
    """@en .

bpacc:EndpointNode a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumNode ;
    rdfs:label "Endpoint Node"@en ;
    skos:definition """
        Tier P — IoT endpoints, embedded devices, robots.
        Lowest capacity tier. Cannot offload to other Endpoints.
        In BPACC use case: SoftBank Pepper robot (Intel Atom E3845, 4GB RAM).
    """@en ;
    skos:example "SoftBank Pepper, Raspberry Pi, Arduino"@en .

bpacc:EdgeNode a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumNode ;
    rdfs:label "Edge Node"@en ;
    skos:definition """
        Tier E — Edge gateways, local compute clusters.
        Medium capacity. Receives offloaded workloads from Endpoints.
        In BPACC use case: Intel Core i7 gateway (16GB RAM, RKE2).
    """@en ;
    skos:example "Edge gateway, local Kubernetes cluster, fog node"@en .

bpacc:CloudNode a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumNode ;
    rdfs:label "Cloud Node"@en ;
    skos:definition """
        Tier C — Cloud data centers, on-premise clusters.
        Highest capacity. Receives offloaded workloads from Endpoints and Edge.
        In BPACC use case: on-premise cluster (~150 vCPU, 2.1TB RAM, Harvester/Rancher).
    """@en ;
    skos:example "AWS EC2, on-premise Kubernetes cluster, HPC node"@en .

# Disjointness des tiers — un nœud ne peut appartenir qu'à un seul tier
[] a owl:AllDisjointClasses ;
    owl:members ( bpacc:EndpointNode bpacc:EdgeNode bpacc:CloudNode ) .


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 2 — PROPRIÉTÉS OBJET
# ══════════════════════════════════════════════════════════════════════════════

# ── Placement structurel (axiomes OWL — vérifiés par HermiT au niveau ABox) ──

bpacc:isDeployedOn a owl:ObjectProperty ;
    rdfs:label "is deployed on"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  bpacc:ContinuumNode ;
    skos:definition """
        Relates a ContinuumService instance to the ContinuumNode on which
        it is deployed. Used by HermiT to enforce placement axioms at ABox level.
        The scheduler selects the concrete instance at runtime via Meligible.
    """@en .

bpacc:canOffloadTo a owl:ObjectProperty ;
    rdfs:label "can offload to"@en ;
    rdfs:domain bpacc:ContinuumNode ;
    rdfs:range  bpacc:ContinuumNode ;
    skos:definition """
        Directed offloading relation between continuum tiers.
        Axioms: P→E, P→C, E→C (from [1]).
    """@en .

# ── Placement descriptif (Pc — pour B1 et B3) ────────────────────────────────
# Différent de isDeployedOn : descriptif, pas une restriction OWL.
# Queryable via SPARQL. Utilisé par B1 pour le matching et par B3 pour fvalidate.
# La sélection de l'instance concrète reste au scheduler au runtime.

bpacc:targetNode a owl:ObjectProperty ;
    rdfs:label "target node"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  bpacc:ContinuumNode ;
    skos:definition """
        Suggested target continuum node tier for this capability.
        Encodes Pc (local governance constraint) in the Capability Profile.
        Used by B1 for contextual matching and by B3 for fvalidate.
        Final placement is resolved by the scheduler at runtime via Meligible.
        Not an OWL restriction — descriptive, queryable via SPARQL.
    """@en .

# ── Capability Profile — Ic (paramètres fonctionnels requis) ─────────────────

bpacc:hasInputParameter a owl:ObjectProperty ;
    rdfs:label "has input parameter"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  bpacc:InputParameter ;
    skos:definition """
        Relates a ContinuumService to its required functional input parameters Ic.
        Used by B1 to populate the params field of the Capability Contract.
    """@en .

# ── Governance ────────────────────────────────────────────────────────────────

bpacc:implementsCapability a owl:ObjectProperty ;
    rdfs:label "implements capability"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  bpacc:AbstractCapability ;
    skos:definition """
        Relates a concrete service implementation to its abstract capability
        class in K. Enables abstract/instance separation (Section III-A-2).
    """@en .

bpacc:hasGovernanceConstraint a owl:ObjectProperty ;
    rdfs:label "has governance constraint"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  bpacc:GovernanceConstraint ;
    skos:definition "Relates a service to its local governance constraints Pc."@en .


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 3 — PROPRIÉTÉS DE DONNÉES
# ══════════════════════════════════════════════════════════════════════════════

# ── Service metadata ──────────────────────────────────────────────────────────

bpacc:serviceId a owl:DatatypeProperty ;
    rdfs:label "service ID"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  xsd:string ;
    skos:definition "Unique identifier of the service, corresponds to M(s).id."@en .

bpacc:serviceVersion a owl:DatatypeProperty ;
    rdfs:label "service version"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  xsd:string .

# ── InputParameter — Ic ───────────────────────────────────────────────────────
# Propriétés des paramètres fonctionnels requis par un service.
# Sérialisées dans le champ params du Capability Contract payload.

bpacc:paramName a owl:DatatypeProperty ;
    rdfs:label "parameter name"@en ;
    rdfs:domain bpacc:InputParameter ;
    rdfs:range  xsd:string ;
    skos:definition """
        Technical variable name (key) used in the Capability Contract params payload.
        Example: 'video_base64', 'duration_seconds', 'text_to_say'.
    """@en .

bpacc:paramLabel a owl:DatatypeProperty ;
    rdfs:label "parameter label"@en ;
    rdfs:domain bpacc:InputParameter ;
    rdfs:range  xsd:string ;
    skos:definition """
        Human-readable label displayed in Camunda Modeler for the Business Analyst.
        Example: 'Image Source (base64 encoded)', 'Recording Duration (seconds)'.
    """@en .

bpacc:paramType a owl:DatatypeProperty ;
    rdfs:label "parameter type"@en ;
    rdfs:domain bpacc:InputParameter ;
    rdfs:range  xsd:string ;
    skos:definition """
        Expected XSD data type of the parameter.
        Allowed values: 'string', 'float', 'boolean', 'integer'.
    """@en .

# ── Qc — SLOs ────────────────────────────────────────────────────────────────

bpacc:latencyProfile a owl:DatatypeProperty ;
    rdfs:label "latency profile"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  xsd:string ;
    skos:definition """
        QoS latency tier for the service. Encodes Qc in the Capability Profile.
        Allowed values: 'critical', 'standard', 'best-effort'.
        Maps to qos.latency in the Capability Contract payload.
        Used by B1 for contextual matching and by B3 for fvalidate.
    """@en .

# ── Pc — Governance constraints ───────────────────────────────────────────────

bpacc:dataLocality a owl:DatatypeProperty ;
    rdfs:label "data locality"@en ;
    rdfs:domain bpacc:ContinuumService ;
    rdfs:range  xsd:string ;
    skos:definition """
        Data placement constraint for GDPR compliance. Encodes Pc.
        Allowed values: 'edge-only', 'endpoint-only', 'edge-preferred',
        'cloud-only', 'none', 'strict'.
        Maps to governance.data_locality in the Capability Contract payload.
    """@en .

bpacc:region a owl:DatatypeProperty ;
    rdfs:label "region"@en ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( bpacc:ContinuumService bpacc:ContinuumNode )
    ] ;
    rdfs:range xsd:string ;
    skos:definition """
        Geographic region constraint for GDPR compliance. Encodes Pc.
        Allowed values: 'eu', 'fr', 'us', 'ap', etc.
        On ContinuumService : required deployment region for this capability.
        On ContinuumNode    : actual region of the node.
        B1 contextualises this from business constraints expressed in the BPMN.
        B3 verifies that the artifact's node region matches the service constraint.
        Maps to governance.region in the Capability Contract payload.
    """@en .

bpacc:nodeCapacity a owl:DatatypeProperty ;
    rdfs:label "node capacity"@en ;
    rdfs:domain bpacc:ContinuumNode ;
    rdfs:range  xsd:integer ;
    skos:definition """
        Abstract capacity score of a continuum node.
        Encodes the invariant Cap(x) < Cap(y) < Cap(z)
        for x∈P, y∈E, z∈C from [1].
    """@en .


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 4 — TAXONOMIE DES SERVICES (5 super-classes)
# Section III-A-1 du papier : Ss, Sa, Sp, Sd, Si
# Les axiomes de placement OWL s'appliquent aux instances (ABox).
# Le scheduler sélectionne les instances concrètes au runtime via Meligible.
# ══════════════════════════════════════════════════════════════════════════════

bpacc:ContinuumService a owl:Class ;
    rdfs:label "Continuum Service"@en ;
    skos:definition """
        Top-level class for all invocable services in the BPACC taxonomy.
        Excludes operational infrastructure services (Sop) per the
        Exclusion property of the reference model [1].
    """@en .

# ── Ss — Sensing Service ──────────────────────────────────────────────────────

bpacc:SensingService a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumService ;
    rdfs:subClassOf sosa:Sensor ;
    rdfs:label "Sensing Service"@en ;
    skos:definition """
        Super-class Ss. Services that capture data from the physical world.
        Placement: Endpoint ∪ Edge ∪ Cloud (all three tiers).
        Examples: audio recording, video capture, environmental sensors.
    """@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty bpacc:isDeployedOn ;
        owl:someValuesFrom [
            a owl:Class ;
            owl:unionOf ( bpacc:EndpointNode bpacc:EdgeNode bpacc:CloudNode )
        ]
    ] .

# ── Sa — Actuation Service ────────────────────────────────────────────────────

bpacc:ActuationService a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumService ;
    rdfs:subClassOf sosa:Actuator ;
    rdfs:label "Actuation Service"@en ;
    skos:definition """
        Super-class Sa. Services that act on the physical world.
        Placement: Endpoint only — actuation requires physical proximity.
        Examples: text-to-speech on robot, motor control, relay actuation.
    """@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty bpacc:isDeployedOn ;
        owl:allValuesFrom bpacc:EndpointNode
    ] .

# ── Sp — Processing Service ───────────────────────────────────────────────────

bpacc:ProcessingService a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumService ;
    rdfs:label "Processing Service"@en ;
    skos:definition """
        Super-class Sp. Services that transform, analyze, or enrich data.
        Placement: Edge ∪ Cloud — requires compute capacity above Endpoint tier.
        Examples: OCR, LLM inference, web search, lead scoring, object detection.
    """@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty bpacc:isDeployedOn ;
        owl:someValuesFrom [
            a owl:Class ;
            owl:unionOf ( bpacc:EdgeNode bpacc:CloudNode )
        ]
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty bpacc:isDeployedOn ;
        owl:allValuesFrom [
            a owl:Class ;
            owl:unionOf ( bpacc:EdgeNode bpacc:CloudNode )
        ]
    ] .

# ── Sd — Storage Service ──────────────────────────────────────────────────────

bpacc:StorageService a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumService ;
    rdfs:label "Storage Service"@en ;
    skos:definition """
        Super-class Sd. Services that persist or retrieve data.
        Placement: Edge ∪ Cloud — persistent storage requires stable infrastructure.
        Examples: CRM, database, file storage.
    """@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty bpacc:isDeployedOn ;
        owl:someValuesFrom [
            a owl:Class ;
            owl:unionOf ( bpacc:EdgeNode bpacc:CloudNode )
        ]
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty bpacc:isDeployedOn ;
        owl:allValuesFrom [
            a owl:Class ;
            owl:unionOf ( bpacc:EdgeNode bpacc:CloudNode )
        ]
    ] .

# ── Si — Interaction Service ──────────────────────────────────────────────────

bpacc:InteractionService a owl:Class ;
    rdfs:subClassOf bpacc:ContinuumService ;
    rdfs:label "Interaction Service"@en ;
    skos:definition """
        Super-class Si. Services that interface with human users.
        Placement: Endpoint ∪ Edge ∪ Cloud (all three tiers).
        Examples: Streamlit UI, dashboard, consent form, sales handoff interface.
    """@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty bpacc:isDeployedOn ;
        owl:someValuesFrom [
            a owl:Class ;
            owl:unionOf ( bpacc:EndpointNode bpacc:EdgeNode bpacc:CloudNode )
        ]
    ] .

# Disjointness des 5 super-classes
[] a owl:AllDisjointClasses ;
    owl:members (
        bpacc:SensingService
        bpacc:ActuationService
        bpacc:ProcessingService
        bpacc:StorageService
        bpacc:InteractionService
    ) .


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 5 — CAPABILITY CATALOG (K)
# Section III-A-1 : K est le sous-ensemble opérationnel du TBox
# ══════════════════════════════════════════════════════════════════════════════

bpacc:AbstractCapability a owl:Class ;
    rdfs:label "Abstract Capability"@en ;
    skos:definition """
        An abstract service capability in K.
        Identified by a semantic ID in the TBox.
        Implemented by one or more concrete ContinuumService instances.
        The Business Analyst interacts only with AbstractCapability,
        never with concrete implementations.
    """@en .

bpacc:CapabilityProfile a owl:Class ;
    rdfs:label "Capability Profile"@en ;
    skos:definition """
        A Capability Profile c ∈ K as defined in Section III-A-2:
        c = ⟨ID, Ic, Qc, Pc⟩
        - ID  : semantic identifier (AbstractCapability IRI)
        - Ic  : required functional input parameters (hasInputParameter)
        - Qc  : applicable SLOs (latencyProfile)
        - Pc  : local governance constraints (dataLocality, targetNode, region)
        Serialized as a Capability Contract JSON payload for B1 and B3.
    """@en .

bpacc:InputParameter a owl:Class ;
    rdfs:label "Input Parameter"@en ;
    skos:definition """
        Describes a parameter required by a capability at runtime.
        Encodes Ic in the Capability Profile.
        Serialized as the params field of the Capability Contract payload.
        Properties: paramName (key), paramLabel (Camunda label), paramType (XSD type).
    """@en .


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 6 — GOVERNANCE
# ══════════════════════════════════════════════════════════════════════════════

bpacc:GovernanceConstraint a owl:Class ;
    rdfs:label "Governance Constraint"@en ;
    skos:definition """
        A governance rule r ∈ Rlocal applicable to a service.
        Evaluated by B3 (Business Policy Repository) via fvalidate.
    """@en .

bpacc:DataLocalityConstraint a owl:Class ;
    rdfs:subClassOf bpacc:GovernanceConstraint ;
    rdfs:label "Data Locality Constraint"@en ;
    skos:definition """
        Constrains where data produced or consumed by a service may reside.
        GDPR use case: biometric data must not leave the Edge.
        Maps to governance.data_locality in the Capability Contract payload.
    """@en .

bpacc:RegionConstraint a owl:Class ;
    rdfs:subClassOf bpacc:GovernanceConstraint ;
    rdfs:label "Region Constraint"@en ;
    skos:definition """
        Constrains the geographic region of the deployment node.
        GDPR use case: personal data must remain within EU territory.
        B1 contextualises this from business constraints in the BPMN.
        B3 verifies compliance at artifact validation time.
        Maps to governance.region in the Capability Contract payload.
    """@en .


# ══════════════════════════════════════════════════════════════════════════════
# SECTION 7 — OFFLOADING AXIOMS
# Directed offloading P→E, P→C, E→C from [1]
# ══════════════════════════════════════════════════════════════════════════════

bpacc:EndpointNode rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty bpacc:canOffloadTo ;
    owl:someValuesFrom [
        a owl:Class ;
        owl:unionOf ( bpacc:EdgeNode bpacc:CloudNode )
    ]
] .

bpacc:EdgeNode rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty bpacc:canOffloadTo ;
    owl:someValuesFrom bpacc:CloudNode
] .

# CloudNode — tier terminal, ne peut pas offloader
bpacc:CloudNode rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty bpacc:canOffloadTo ;
    owl:maxCardinality "0"^^xsd:nonNegativeInteger
] .
