  <rdf:Description rdf:about="http://bpacc.bpacc.com/ontology#AbstractCapability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Abstract Capability</rdfs:label>
    <skos:definition xml:lang="en">
        An abstract service capability in K.
        Identified by a semantic ID in the TBox.
        Implemented by one or more concrete ContinuumService instances.
        The Business Analyst interacts only with AbstractCapability,
        never with concrete implementations.
    </skos:definition>
  </rdf:Description>
