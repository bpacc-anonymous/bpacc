    <owl:unionOf rdf:nodeID="n30ca8f3e052743a889489f8372607640b10"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n30ca8f3e052743a889489f8372607640b31">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="n30ca8f3e052743a889489f8372607640b32"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n30ca8f3e052743a889489f8372607640b35">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
    <owl:members rdf:nodeID="n30ca8f3e052743a889489f8372607640b36"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n30ca8f3e052743a889489f8372607640b16">
    <rdf:first rdf:resource="http://bpacc.bpacc.com/ontology#EdgeNode"/>
    <rdf:rest rdf:nodeID="n30ca8f3e052743a889489f8372607640b17"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://bpacc.bpacc.com/ontology#paramLabel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">parameter label</rdfs:label>
    <rdfs:domain rdf:resource="http://bpacc.bpacc.com/ontology#InputParameter"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <skos:definition xml:lang="en">
        Human-readable label displayed in Camunda Modeler for the Business Analyst.
        Example: 'Image Source (base64 encoded)', 'Recording Duration (seconds)'.
    </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n30ca8f3e052743a889489f8372607640b19">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="n30ca8f3e052743a889489f8372607640b20"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://bpacc.bpacc.com/ontology#InputParameter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Input Parameter</rdfs:label>
    <skos:definition xml:lang="en">
        Describes a parameter required by a capability at runtime.
        Encodes Ic in the Capability Profile.
        Serialized as the params field of the Capability Contract payload.
        Properties: paramName (key), paramLabel (Camunda label), paramType (XSD type).
    </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://bpacc.bpacc.com/ontology#EndpointNode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://bpacc.bpacc.com/ontology#ContinuumNode"/>
    <rdfs:subClassOf rdf:nodeID="n30ca8f3e052743a889489f8372607640b41"/>
    <rdfs:label xml:lang="en">Endpoint Node</rdfs:label>
    <skos:definition xml:lang="en">
        Tier P — IoT endpoints, embedded devices, robots.
        Lowest capacity tier. Cannot offload to other Endpoints.
        In BPACC use case: SoftBank Pepper robot (Intel Atom E3845, 4GB RAM).
    </skos:definition>
    <skos:example xml:lang="en">SoftBank Pepper, Raspberry Pi, Arduino</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="http://bpacc.bpacc.com/ontology#hasInputParameter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has input parameter</rdfs:label>
    <rdfs:domain rdf:resource="http://bpacc.bpacc.com/ontology#ContinuumService"/>
    <rdfs:range rdf:resource="http://bpacc.bpacc.com/ontology#InputParameter"/>
    <skos:definition xml:lang="en">
        Relates a ContinuumService to its required functional input parameters Ic.
        Used by B1 to populate the params field of the Capability Contract.
    </skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n30ca8f3e052743a889489f8372607640b29">
